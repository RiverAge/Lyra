{
  "name": "lyra-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "lint": "node ../scripts/quality-gate/frontend/style-guard.mjs && eslint \"src/**/*.{ts,vue}\"",
    "lint:fix": "eslint \"src/**/*.{ts,vue}\" --fix",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "prepare": "cd .. && husky"
  },
  "lint-staged": {
    "src/**/*.{ts,vue}": "eslint --max-warnings=0 --no-warn-ignored"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.3",
    "@types/node": "^24.7.2",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.37.0",
    "eslint-plugin-vue": "^10.5.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "tailwindcss": "^4.2.3",
    "typescript": "^5.6.3",
    "unplugin-auto-import": "^20.3.0",
    "vite": "^6.0.1",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^2.1.10"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "packageManager": "pnpm@9.14.0+sha256.36578895ec3f6ff19f98f10b4e33ff0f4fa29e2897901600fd2e3dc927da46a7"
}
